# AngoraPay Mesh / Angora integration mode
# Leave blank to keep public demo endpoints open locally. Set in deployed demos.
ANGORA_API_KEY=
KAIROS_ANGORA_API_KEY=

# Real x402 through existing Kairos paying client. Mock mode is default.
KAIROS_ENABLE_REAL_X402=false

# If true, mock mode is clearly labelled as Arc testnet simulation instead of generic fallback.
ANGORA_DEMO_ARC_TESTNET=false

# Angora event window for the submission metrics endpoint.
ANGORA_EVENT_START=2026-05-11
ANGORA_EVENT_END=2026-05-25

# Production AI reasoning
# With OPENAI_API_KEY set, Angora uses OpenAI for mission interpretation and recommendation summaries.
# Policy, spend, provider routing, payments, receipts, and reconciliation remain deterministic.
ANGORA_LLM_ENABLED=true
ANGORA_LLM_MODEL=gpt-5.4-mini
ANGORA_LLM_TIMEOUT_MS=12000
OPENAI_API_KEY=

# Optional metadata for traction attribution.
ANGORA_PUBLIC_DEMO_URL=
ANGORA_TRACTION_SOURCES=canteen,arc-discord,circle,linkedin,x,hackathon,manual

# Existing Kairos/Circle/Arc variables still apply when KAIROS_ENABLE_REAL_X402=true.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=
AGENT_WALLET_ADDRESS=
OWS_RPC_URL=https://rpc.testnet.arc.network
OWS_CHAIN_ID=5042002

# Angora hardening additions
ANGORA_RATE_LIMIT_WINDOW_MS=60000
ANGORA_RATE_LIMIT_MAX=120
ANGORA_GATEWAY_RATE_LIMIT_MAX=60
ANGORA_IDEMPOTENCY_TTL_MS=86400000
ANGORA_SETTLEMENT_DEMO_MIN_AGE_MS=30000
ANGORA_LOG_TO_CONSOLE=false

# Angora hardened auth / workspace isolation
# Prefer hashed API keys via /v1/angora/auth/keys. Legacy env key is still supported for bootstrap/admin.
ANGORA_REQUIRE_AUTH=true
ANGORA_DEFAULT_WORKSPACE_ID=novtia-demo
ANGORA_DEFAULT_TENANT_ID=novtia
ANGORA_API_KEY_PREFIX=ag_live
# ANGORA_AUTH_DISABLED=false
# ANGORA_STATE_DIR=/var/lib/kairos/angora
# KAIROS_DATA_DIR=/var/lib/kairos

# Optional settlement hydration endpoint if Kairos/Circle runtime exposes one
# ANGORA_SETTLEMENT_HYDRATION_URL=https://api.kairos.example/v1/settlement/hydrate
# ANGORA_SETTLEMENT_HYDRATION_API_KEY=
